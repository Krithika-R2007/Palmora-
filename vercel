{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/db run push && pnpm --filter @workspace/api-spec run codegen && pnpm --filter @workspace/paloma run build",
  "outputDirectory": "artifacts/paloma/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
